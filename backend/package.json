{
  "name": "stalkerweb-backend",
  "version": "1.0.0",
  "description": "Stalker Middleware web service — Docker backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
