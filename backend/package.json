{
  "name": "stalkerweb-backend",
  "version": "1.0.0",
  "description": "Stalker Middleware web service — Docker backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-cookiejar-support": "^7.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.3.2",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "prettier": "^3.5.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
