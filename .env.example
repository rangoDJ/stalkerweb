PORT=3000
DATA_DIR=./data
NODE_ENV=production

# Optional: Pre-configure a portal at startup
# PORTAL_URL=http://your.portal.url/c/
# PORTAL_MAC=00:1A:79:XX:XX:XX
# PORTAL_TIMEZONE=America/New_York

# Live log monitor (/api/logs, /api/logs/stream)
# Without a token the endpoint is reachable only from localhost (same host/
# container). Set a token to allow a remote agent to connect.
# LOG_MONITOR_TOKEN=change-me
# LOG_BUFFER_SIZE=1000   # number of recent log lines kept in memory
